{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aluforma",
  "compatibility_date": "2026-06-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "**/.git/**",
      ".git/**",
      ".git",
      "wrangler.jsonc",
      ".gitignore",
      ".wranglerignore"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
